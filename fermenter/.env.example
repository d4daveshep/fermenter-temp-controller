# Copy this file to .env (i.e. fermenter/.env) and adjust for this host
# before running `docker compose up` from the repo root.
#
# See openspec/specs/system-configuration/spec.md and
# docs/rewrite-plan.md §9 for the full set of recognised variables; all have
# in-code defaults (src/config.rs) except where noted, so only override what
# needs to differ from those defaults for this deployment.

# Serial device path for the attached Arduino. Differs between hosts (the
# dev machine used /dev/ttyACM0 during slice-6; the Pi may assign a
# different path — prefer /dev/serial/by-id/... if multiple USB-serial
# devices are attached). Also used by compose.yaml's `devices:` mapping.
SERIAL_PORT=/dev/ttyACM0

# Baud rate matching the fixed Arduino firmware contract. Should not need to
# change.
SERIAL_BAUD=115200

# false = real Arduino via ArduinoSerialSource (slice-6); true = hardware-free
# MockSerialSource. Real deployment should leave this false.
MOCK_SERIAL=false

# Redis connection URL. `redis` here refers to the Compose service name, not
# localhost — Compose's internal DNS resolves it within the stack's network.
REDIS_URL=redis://redis:6379

# Time-series retention, in days.
TS_RETENTION_DAYS=7

# Brew identifier used to tag persisted readings/state until changed at
# runtime via the dashboard's brew form.
DEFAULT_BREW_ID=00-TEST-v00

# Port the web server binds to inside the container; also used by
# compose.yaml's port mapping and healthcheck.
HTTP_PORT=8080

# Fallback target temperature (°C), used only if no persisted state exists
# yet.
DEFAULT_TARGET_TEMP=19.5

# Log verbosity (tracing-subscriber env-filter syntax), e.g. info, debug.
RUST_LOG=info

# Timezone for the dashboard's server-time timestamp and any other wall-clock
# display. Read directly by the libc tzset() call inside the container
# (chrono::Local) — not parsed by the app's Config. Set to your local IANA
# zone name so the timestamp shows local time instead of the container's
# default UTC. Pacific/Auckland covers both NZST (UTC+12) and NZDT (UTC+13).
TZ=Pacific/Auckland
